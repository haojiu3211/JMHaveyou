APPLICATION_EXTENSION_API_ONLY = NO
BUILD_LIBRARY_FOR_DISTRIBUTION = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/NEChatUIKit
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym
EXCLUDED_ARCHS[sdk=iphonesimulator*] = arm64
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CocoaLumberjack" "${PODS_CONFIGURATION_BUILD_DIR}/MJRefresh" "${PODS_CONFIGURATION_BUILD_DIR}/SDWebImage" "${PODS_CONFIGURATION_BUILD_DIR}/SDWebImageSVGKitPlugin" "${PODS_CONFIGURATION_BUILD_DIR}/SDWebImageWebPCoder" "${PODS_CONFIGURATION_BUILD_DIR}/SVGKit" "${PODS_CONFIGURATION_BUILD_DIR}/libwebp" "${PODS_ROOT}/NEChatKit" "${PODS_ROOT}/NEChatUIKit" "${PODS_ROOT}/NECommonKit" "${PODS_ROOT}/NECommonUIKit" "${PODS_ROOT}/NECoreIM2Kit" "${PODS_ROOT}/NECoreKit" "${PODS_ROOT}/NIMSDK_LITE/NIMSDK" "${PODS_ROOT}/YXAlog" "${PODS_ROOT}/YXArtemis_XCFramework" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NEChatKit/NOS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NEChatUIKit/NOS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NECommonKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NECommonUIKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NECoreIM2Kit/NOS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NECoreKit" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NIMSDK_LITE/FTS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/NIMSDK_LITE/NOS" "${PODS_XCFRAMEWORKS_BUILD_DIR}/YXAlog" "${PODS_XCFRAMEWORKS_BUILD_DIR}/YXArtemis_XCFramework"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "AVFoundation" -framework "AudioToolbox" -framework "CoreMedia" -framework "CoreTelephony" -framework "NEChatKit" -framework "NECommonKit" -framework "NECommonUIKit" -framework "NECoreIM2Kit" -framework "NECoreKit" -framework "NIMDBEx" -framework "NIMNOS" -framework "NIMQuic" -framework "NIMSDK" -framework "NIMSocketRocket" -framework "SystemConfiguration" -framework "VideoToolbox" -framework "YXAlog_iOS" -framework "YXArtemis"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/NEChatUIKit
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
