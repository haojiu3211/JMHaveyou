platform :ios, '15.0'

target 'haveseeyou' do
  use_frameworks!

  # 网络
  pod 'Alamofire', '~> 5.8'
  # 布局
  pod 'SnapKit', '~> 5.7'
  # 图片加载
  pod 'Kingfisher', '~> 7.10'
  # 图片选择（本地源码管理，源码位于 ./LocalPods/YPImagePicker）
  pod 'YPImagePicker', :path => './LocalPods/YPImagePicker'
  # oss上传头像
  pod 'AliyunOSSiOS'
#云信
  pod 'NIMSDK_LITE'
  pod 'NEChatUIKit', '~> 10.9.0'
  pod 'NTESQuickPass', '~> 3.6.3'
end
